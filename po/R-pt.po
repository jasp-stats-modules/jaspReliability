msgstr "%1$s%2$s"

msgid ""
"Omega calculation with CFA failed.\n"
"                                                    Try changing to PFA in "
"'Advanced Options'."
msgstr ""
"O calculo do intervalo de Ômega com CFA falhou.\n"
"                                          Tente trocar para PFA em 'Opções "
"Avançadas'."

msgid ""
"Omega bootstrapped interval calculation with CFA failed.\n"
"                                                        Try changing to PFA "
