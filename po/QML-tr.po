msgctxt "RaterAgreement|"
msgid "Options for confidence intervals and bootstrap settings."
msgstr ""

#, fuzzy
msgctxt "RaterAgreement|"
msgid "Confidence interval"
msgstr "Güven aralığı"

msgctxt "RaterAgreement|"
msgid ""
"Report a confidence interval for each agreement coefficient. Cohen's kappa "
"and Fleiss' kappa use asymptotic CIs; Krippendorff's alpha and Kendall's W "
"use bootstrap CIs."
msgstr ""

msgctxt "RaterAgreement|"
msgid "Width of the confidence interval."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Number of bootstrap replications used to compute confidence intervals. "
"Higher values give more stable estimates. Only applies to Krippendorff's "
"alpha and Kendall's W, whose CIs are bootstrap-based."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Items to include in the SEM analysis. Must be ordinally or nominally scaled "
"(dichotomous or polytomous)."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"CTT-based methods that split the test into parts to estimate the conditional "
"error variance per sum score."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Splits items into odd- and even-numbered halves. Reorder variables in the "
"list to change the split."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Splits items into multiple equal parts to estimate error variance per score "
"group."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"How many equal parts to split the test into. Must be a divisor of the number "
"of items."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Splits items into parts and models score differences with polynomial "
"regression to estimate the conditional SEM."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Degree of the polynomial used to predict score differences, e.g., 3 fits Y = "
"X + X² + X³."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Estimates conditional SEM from a repeated-measures ANOVA using the ICC(3,k) "
"approach (Emons, 2023)."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"IRT-based SEM using the 2PLM for dichotomous items or the graded response "
"model for polytomous items. Assumes a single latent variable."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Methods based on the binomial error model. Only available for dichotomous "
"(non-ordinal) items."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Lord's binomial method based on the number of correct and incorrect "
"responses."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Keats' correction of Lord's method; uses a reliability coefficient to reduce "
"bias."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid "Lord's method generalised to multiple test parts."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"How many parts to split the test into. Must be a divisor of the number of "
"items (excluding the last value)."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Table of sum scores with normal-theory confidence intervals computed from "
"the estimated SEM."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Override the reliability estimate used for the unconditional SEM and the "
"Keats method."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Score groups with fewer observations are merged with adjacent groups before "
"estimating the SEM (default: 20). Applies to the Thorndike, Feldt, ANOVA, "
"and Lord generalized methods."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Hide the main SEM table showing conditional error estimates per sum score "
"and method."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid "Histogram of the number of respondents per sum score group."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Separate point plot per method showing the conditional SEM values across sum "
"scores."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Combined plot displaying all methods' SEM values in a single panel for easy "
"comparison."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Plot sum scores with confidence interval bands per method. Intervals are "
"normal-theory CIs using the estimated SEM."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid "Add a horizontal reference line at the specified cut score."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Items/variables to include in the reliability analysis. Must be scale "
"variables."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Reliability coefficients and descriptive statistics computed for the full "
"scale."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Width of the credible interval for scale reliability statistics."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"McDonald's omega for unidimensional data based on the single-factor model."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Cronbach's alpha. For binary items this equals KR-20."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Guttman's lambda 2, a lower bound for reliability."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Splits items into two halves (odd/even by default). Unstandardized: Flanagan-"
"Rulon; Standardized: Spearman-Brown."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Mean of all pairwise Pearson correlations between items."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Whether the mean, variance, and SD are based on sum scores or mean scores "
"across items."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Reliability coefficients and descriptive statistics per item, including "
"posterior distributions when that item is removed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Width of the credible interval for item-level statistics."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Posterior distribution of omega for the remaining items when this item is "
"removed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Posterior distribution of alpha for the remaining items when this item is "
"removed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Posterior distribution of lambda 2 for the remaining items when this item is "
"removed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Posterior distribution of the split-half coefficient for the remaining items "
"when this item is removed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Displays posterior densities of the reliability of the remaining items when "
"each item is dropped."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Sort the densities by how much removing an item changes the posterior (by "
"mean, KL-divergence, or KS-distance)."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Correlation of each item with the sum of the remaining items."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Display posterior density plots for the selected reliability coefficients."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Fix the x-axis of the posterior plots to [0, 1] for easier comparison "
"between coefficients."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Add the prior distribution to the posterior density plot."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Report the prior and posterior probability that a reliability coefficient "
"falls within the specified interval."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Shade the posterior region corresponding to the probability interval in the "
"density plot."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Parameters controlling the MCMC sampler used to estimate the posterior "
"distributions."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Total number of MCMC iterations per chain, including burn-in. The number of "
"retained posterior samples per chain is ceiling((samples - burn-in) / "
"thinning)."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Initial samples discarded while the chain converges to the posterior."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Keep every k-th sample to reduce autocorrelation. A value of 1 keeps all "
"samples."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Number of independent MCMC chains. Multiple chains enable R-hat convergence "
"diagnostics."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"MCMC convergence diagnostics to assess whether the sampler has converged to "
"the posterior."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Potential scale reduction factor. Values close to 1 (< 1.1) indicate "
"convergence across chains."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Plot of sampled values per chain over iterations. Well-mixed chains indicate "
"convergence."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Effective sample size: number of independent posterior samples after "
"accounting for autocorrelation."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Set a random seed to reproduce identical posterior samples across runs."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"When checked, MCMC samples are not stored in the output file. Reduces file "
"size but may slow down re-running the analysis, because samples are "
"precomputed and cached for speed."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"The prior on alpha, lambda 2, and the split-half is induced by an inverse "
"Wishart prior on the covariance matrix."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Precision values on the diagonal of the inverse Wishart scaling matrix."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Degrees of freedom of the inverse Wishart prior. Minimum equals the number "
"of items."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"The prior on omega is induced by an inverse gamma on residual variances and "
"a normal prior on factor loadings."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Shape parameter of the inverse gamma prior on residual variances."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Scale parameter of the inverse gamma prior on residual variances."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid "Mean of the normal prior on factor loadings."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Bayesian imputation treats missing values as unknown parameters sampled from "
"the posterior; listwise deletion removes any row with a missing value."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Options for fitting the single-factor model underlying McDonald's omega."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Graphical check for single-factor model fit: eigenvalues of the observed "
"covariance matrix are compared against the model-implied posterior "
"distribution."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Bayesian fit indices (B-LR, B-RMSEA, B-CFI, B-TLI) for the single-factor "
"model with probability statements relative to cutoffs."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Table of standardized loadings from the single-factor model (posterior mean "
"or median)."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Unstandardized uses the covariance matrix; standardized uses the correlation "
"matrix. Standardized alpha is contested in the literature."
msgstr ""

msgctxt "UnidimensionalReliabilityBayesian|"
msgid ""
"Whether to report the posterior mean or median as the point estimate in the "
"tables."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Items/variables to include in the reliability analysis. Must be scale "
"variables."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Reliability coefficients and descriptive statistics computed for the full "
"scale."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Coverage of the confidence intervals for scale reliability statistics."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"McDonald's omega for unidimensional data based on the single-factor model. "
"The denominator uses model-implied total variance."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Cronbach's alpha. For binary items this equals KR-20."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Guttman's lambda 2, a lower bound for reliability."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Splits items into two halves (odd/even by default). Unstandardized: Flanagan-"
"Rulon coefficient; Standardized: Spearman-Brown coefficient."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Mean of all pairwise Pearson correlations between items."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Whether the mean, variance, and SD are based on sum scores or mean scores "
"across items."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Reliability coefficients and descriptive statistics per item, including what-"
"if statistics when that item is removed."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Coverage of the confidence intervals for item-level statistics."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Omega of the remaining items when this item is removed from the scale."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Alpha of the remaining items when this item is removed from the scale."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Lambda 2 of the remaining items when this item is removed from the scale."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Split-half coefficient of the remaining items when this item is removed from "
"the scale."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Correlation of each item with the sum of the remaining items."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Control the method used to construct confidence intervals for reliability "
"coefficients, variance, and SD."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Analytic intervals use normal-theory standard errors (van der Ark, 2024). "
"Bootstrapped intervals use percentile resampling."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Number of bootstrap replications. Higher values yield more stable interval "
"estimates."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Non-parametric bootstrap resamples the data; parametric bootstrap samples "
"from a multivariate normal with the estimated parameters."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Chi-square-based intervals assume normality; non-parametric intervals use a "
"two-step bootstrap procedure (van der Ark, 2024)."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"CFA fits the single-factor model via confirmatory factor analysis; PFA uses "
"principal factor analysis."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Chi-square test, RMSEA, SRMR and other fit indices for the single-factor "
"model underlying omega."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Table of standardized loadings from the single-factor model."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Unstandardized coefficients use the raw covariance matrix; standardized use "
"the correlation matrix."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"Pairwise uses all available observations per covariance pair; listwise "
"deletes any row with a missing value."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid "Set a random seed to reproduce the same bootstrap results across runs."
msgstr ""

msgctxt "UnidimensionalReliabilityFrequentist|"
msgid ""
"When checked, bootstrap samples are not stored in the output file. This "
"reduces file size but may slow down re-running the analysis, because samples "
"are precomputed and cached for speed."
msgstr ""
