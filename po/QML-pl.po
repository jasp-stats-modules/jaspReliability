msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Combined plot displaying all methods' SEM values in a single panel for easy "
"comparison."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid ""
"Plot sum scores with confidence interval bands per method. Intervals are "
"normal-theory CIs using the estimated SEM."
msgstr ""

msgctxt "StandardErrorOfMeasurement|"
msgid "Add a horizontal reference line at the specified cut score."
msgstr ""

