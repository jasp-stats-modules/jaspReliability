msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Each column is one rater and each row is one subject or item being rated."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Each row is one rater and each column is one subject or item being rated."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Measures agreement between exactly two raters. When more than two raters are "
"entered, all pairwise combinations are computed."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Unweighted kappa treats all disagreements equally. Weighted kappa accounts "
"for the degree of disagreement and requires ordinal ratings."
msgstr ""

msgctxt "RaterAgreement|"
msgid "All disagreements are treated as equal regardless of their magnitude."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Disagreements are penalised according to their magnitude. Requires ordinal "
"ratings."
msgstr ""

msgctxt "RaterAgreement|"
msgid "Weighting scheme applied to disagreements between ordinal categories."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Penalises larger disagreements quadratically; sensitive to large "
"discrepancies."
msgstr ""

msgctxt "RaterAgreement|"
msgid "Penalises disagreements proportionally to their size."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Measures agreement among two or more raters. Applicable to nominal, ordinal, "
"interval, or ratio data."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Level of measurement determines how disagreements are quantified in the "
"alpha calculation."
msgstr ""

msgctxt "RaterAgreement|"
msgid "Kendall's W"
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Measures concordance among multiple raters on ordinal rankings. Ranges from "
"0 (no agreement) to 1 (perfect agreement)."
msgstr ""

msgctxt "RaterAgreement|"
msgid "Correct for ties"
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Apply a correction to Kendall's W when tied ranks are present in the data. "
"Recommended whenever ties can occur."
msgstr ""

msgctxt "RaterAgreement|"
msgid ""
"Measures agreement among two or more raters on nominal categories. "
"Generalises Cohen's kappa to multiple raters."
msgstr ""

